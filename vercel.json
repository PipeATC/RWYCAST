{
  "version": 2,
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/((?!js/|icon-512\\.png|manifest\\.webmanifest|styles\\.css|sw\\.js).*)", "destination": "/index.html" }
  ]
}
